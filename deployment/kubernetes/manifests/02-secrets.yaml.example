---
# This is an example file. Copy to 02-secrets.yaml and fill in the actual values.
# DO NOT commit 02-secrets.yaml to Git!
apiVersion: v1
kind: Secret
metadata:
  name: tripsphere-secrets
  namespace: tripsphere
type: Opaque
stringData:
  # Database Passwords
  MONGODB_ROOT_PASSWORD: "fudanse"
  MYSQL_ROOT_PASSWORD: "fudanse"
  MYSQL_USER: "root"
  MYSQL_PASSWORD: "fudanse"
  NEO4J_PASSWORD: "fudanse@fudan.edu.cn"
  NEO4J_USERNAME: "neo4j"
  
  # MinIO Credentials
  MINIO_ACCESS_KEY: "minioadmin"
  MINIO_SECRET_KEY: "minioadmin"
  
  # Nacos Authentication
  NACOS_USERNAME: "nacos"
  NACOS_PASSWORD: "nacos"
  
  # OpenAI API Key (replace with actual key)
  OPENAI_API_KEY: "your-openai-api-key-here"
  
  # Spring Datasource (for user-service)
  SPRING_DATASOURCE_USERNAME: "root"
  SPRING_DATASOURCE_PASSWORD: "fudanse"
  SPRING_DATASOURCE_URL: "jdbc:mysql://mysql.tripsphere.svc.cluster.local:3306/user_db?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true"
