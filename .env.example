# TripSphere environment configuration

# MongoDB
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=root
MONGODB_PASSWORD=fudanse

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=fudanse

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Nacos
NACOS_HOST=nacos
NACOS_PORT=8848
# Credentials used by Go/Python clients to authenticate with Nacos
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
# Server-side auth token (base64-encoded secret key, minimum 32 chars)
NACOS_AUTH_TOKEN="VGhpc0lzTXlDdXN0b21TZWNyZXRLZXkwMTIzNDU2Nzg="

# MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Neo4j
NEO4J_HOST=neo4j
NEO4J_PORT=7687
# Password for the built-in 'neo4j' user
NEO4J_PASSWORD=fudanse@fudan.edu.cn

# RocketMQ
# Point at rmq-proxy (the gRPC proxy endpoint)
ROCKETMQ_HOST=rmq-proxy
ROCKETMQ_PORT=8081

# Higress / AI Gateway
# After starting the stack, open the Higress console at http://<host>:8001
# and register your AI provider (e.g. OpenAI, DeepSeek) with the real API key.
# Application services talk to Higress; they never see the actual API key.
HIGRESS_HOST=higress
HIGRESS_HTTP_PORT=8080
# Placeholder required by OpenAI-compatible SDK clients; the real key lives in Higress.
OPENAI_API_KEY=openai-api-key

# Frontend
# RSA public key used by the Next.js frontend to verify JWTs issued by user service.
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAlAT+QlJbdW9Q8bLlORv0
FS+QoswqlMY6cXJePz8NFT4PBa/oi0Qa5bk5Kyr234yZ5EVlmTKtw64ZXX5tsvnv
Bd8nf+uI5xXHMAdpuBvGvwkhxUY4GvYLjuj6T/kKHsAgXPvbq5hvDDqA0rRbtmpE
oFImR4kQOFlvikndyMGlWOoq2/PTE40NQP5xIrooi1dPD1ZwYxHOuFgoWaCRE8SH
Jg9qOPqMJxHPNCUcxWt2ckNsTc39PTqSt1a930u5sgWWJc7sIwUF3++7Fy8CI4+x
7OdDfR/ECoAy1muJLamVyJE3wPyvF3DklTlkaITWE/WaKpQlHZDUgycSIWFBT3F5
WwIDAQAB
-----END PUBLIC KEY-----"

# Initializer (optional, one-shot data seeding)
# Required only when running infra/initializer to generate seeded data.
AMAP_KEY=
